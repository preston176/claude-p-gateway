# Required in production; defaults to "dev-token-change-me" in dev/test
GATEWAY_TOKEN=change-me-to-a-long-random-string

# Optional overrides
PORT=4000
# CLAUDE_BIN=/usr/local/bin/claude

# Persist runtime settings (gateway token, rate limit knobs) across restarts.
# Without this, the admin page works but its changes are in-memory only.
# STATE_PATH=/var/lib/claude-p-gateway/state.json

# Set both to expose /admin/settings and /admin/dashboard behind BasicAuth.
# Leave unset to 404 those routes.
# DASHBOARD_USER=admin
# DASHBOARD_PASS=change-me-too

# Required in production only (mix phx.gen.secret 64)
# SECRET_KEY_BASE=
# PHX_HOST=gateway.example.com
# PHX_SERVER=true
