# Copy this to /etc/claude-p-gateway/env (chmod 600) on the VPS and edit.
# Loaded by systemd via EnvironmentFile=.

# Phoenix
PHX_SERVER=true
PHX_HOST=gateway.example.com
PORT=4000
SECRET_KEY_BASE=__GENERATE_WITH_mix_phx.gen.secret_64__

# Gateway
GATEWAY_TOKEN=__LONG_RANDOM_STRING__

# Optional: pin the claude binary path if it's not on the service user's PATH.
# CLAUDE_BIN=/usr/local/bin/claude

# Optional: enable /admin/dashboard with BasicAuth. Leave unset to 404 the route.
# DASHBOARD_USER=admin
# DASHBOARD_PASS=__LONG_RANDOM_STRING__
